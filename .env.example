# ─── OpenAI (instance self-hosted) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://toknroutertybot.tybotflow.com/
OPENAI_MODEL=gpt-4o-mini            # optionnel (défaut : gpt-4o-mini)

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...          # clé service role (admin, bypass RLS)

# ─── JWT (optionnel — auto-généré si absent) ─────────────────────────────────
JWT_SECRET=

# ─── Worker de sync Meta → Supabase (optionnel) ──────────────────────────────
# Intervalle entre deux synchronisations automatiques (minutes). Défaut : 20.
FB_SYNC_INTERVAL_MINUTES=20
# Lancer un sync immédiat au démarrage du serveur (true/false). Défaut : true.
FB_SYNC_ON_STARTUP=true

# Note : les credentials Meta (token, ad account, page, pixel) sont stockés PAR
# COMPTE dans la table Supabase `meta_accounts` (page Settings), pas ici.
