# pnpm 11 relance un `install` avant chaque script et échoue sur les build scripts
# non approuvés (esbuild, etc.). On désactive ce contrôle : `pnpm test` lance
# alors vitest directement. La CI fait son `install` explicitement (cf. ci.yml).
verify-deps-before-run=false

# Autorise les build scripts nécessaires (binaire esbuild requis par vite/vitest).
# Sans ça, un install neuf (CI) ignore le postinstall d'esbuild → vitest casse.
enable-pre-post-scripts=true
